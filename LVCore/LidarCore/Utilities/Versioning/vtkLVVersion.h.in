#ifndef vtkLVVersion_h
#define vtkLVVersion_h

#define LIDARVIEW_VERSION_MAJOR @LIDARVIEW_VERSION_MAJOR@
#define LIDARVIEW_VERSION_MINOR @LIDARVIEW_VERSION_MINOR@
#define LIDARVIEW_VERSION_PATCH @LIDARVIEW_VERSION_PATCH@
#define LIDARVIEW_VERSION "@LIDARVIEW_VERSION@"
#define LIDARVIEW_VERSION_FULL "@LIDARVIEW_VERSION_FULL@"

#define LIDARVIEW_VERSION_CHECK(major, minor, build)                                                     \
  (10000000000ULL * major + 100000000ULL * minor + build)
#define LIDARVIEW_VERSION_NUMBER                                                                         \
  LIDARVIEW_VERSION_CHECK(LIDARVIEW_VERSION_MAJOR, LIDARVIEW_VERSION_MINOR, LIDARVIEW_VERSION_PATCH)

#define SOFTWARE_NAME "@SOFTWARE_NAME@"
#define SOFTWARE_VENDOR "@SOFTWARE_VENDOR@"

#cmakedefine LIDARVIEW_HIDE_DEPRECATION_WARNINGS

#endif
