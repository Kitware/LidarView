#ifndef vtkPacketFilePositionType_h
#define vtkPacketFilePositionType_h

// Compliance with vtk's fpos_t policy, needs to be included before any libc header
#include <vtkSystemIncludes.h>

#include <cstdint>

#if defined(_WIN32)
#cmakedefine LIDARVIEW_USE_NPCAP
#if defined(LIDARVIEW_USE_NPCAP)
#define LIBPCAP_INDEXING_SUPPORTED
#endif
#else
#define LIBPCAP_INDEXING_SUPPORTED
#endif

#if defined(LIBPCAP_INDEXING_SUPPORTED)
typedef int64_t vtkPcapIdxType;
#else
typedef fpos_t vtkPcapIdxType;
#endif

#endif
