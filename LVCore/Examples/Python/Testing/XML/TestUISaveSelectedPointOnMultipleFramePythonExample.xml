<?xml version="1.0" ?>
<pqevents>
  <!-- Prepare variable before executing example -->
  <pqevent object="LidarViewMainWindow/mainControlsToolbar/actionPythonShell" command="activate" arguments="" />
  <pqevent object="LidarViewMainWindow/pythonShellDock/pythonShell/consoleWidget" command="executeCommand" arguments="from lidarviewexamples.save_selected_point_on_multiple_frames import SaveSelectPointsOnMultipleFrames" />
  <pqevent object="LidarViewMainWindow/pythonShellDock/pythonShell/consoleWidget" command="executeCommand" arguments="reader = OpenPCAP('$PARAVIEW_DATA_ROOT/Slam/VLP-16_slam_test_data.pcap', 'VLP-16', 'Velodyne')" />
  <pqevent object="LidarViewMainWindow/pythonShellDock/pythonShell/consoleWidget" command="executeCommand" arguments="timesteps = range(88, 97)" />

  <!-- Call SaveSelectPointsOnMultipleFrames example -->
  <pqevent object="LidarViewMainWindow/pythonShellDock/pythonShell/consoleWidget" command="executeCommand" arguments="SaveSelectPointsOnMultipleFrames('$PARAVIEW_TEST_ROOT/TestSaveSelectPointsOnMultipleFrames.csv', timesteps)" />

  <!-- Only show selected points -->
  <pqevent object="LidarViewMainWindow/pipelineBrowserDock/pipelineBrowser" command="mousePress" arguments="1,1,0,7,13,/0:0/1:0/0:0/0:1" />
  <pqevent object="LidarViewMainWindow/pipelineBrowserDock/pipelineBrowser" command="mouseRelease" arguments="1,0,0,7,13,/0:0/1:0/0:0/0:1" />
  <pqevent object="LidarViewMainWindow/pipelineBrowserDock/pipelineBrowser" command="mousePress" arguments="1,1,0,12,12,/0:0/0:0/0:0/0:1" />
  <pqevent object="LidarViewMainWindow/pipelineBrowserDock/pipelineBrowser" command="mouseRelease" arguments="1,0,0,12,12,/0:0/0:0/0:0/0:1" />
</pqevents>
