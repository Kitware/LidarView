<ServerManagerConfiguration>
  <ProxyGroup name="internal_interpreter">
    <!-- ==================================================================== -->
    <!-- Common position orientation live source stream -->
    <SourceProxy name="CommonPositionOrientationStream"
                 class="vtkPositionOrientationStream"
                 base_proxygroup="internal_interpreter"
                 base_proxyname="BaseStream">

      <OutputPort name="Position Orientation" index="0" />
      <OutputPort name="Raw informations" index="1" />

      <!-- Please notice that this Property is duplicate so that:
          it can be place in a user friendly location in the generate GUI -->
      <ProxyProperty name="PacketInterpreter"
                     command="SetPosOrInterpreter"
                     label="Interpreter">
        <ProxyListDomain name="proxy_list">
          <Group name="PositionOrientationPacketInterpreter" />
        </ProxyListDomain>
      </ProxyProperty>

      <Hints>
        <!-- Force the pipeline to try to update the stream every 10 millisecond in case new data are available.
            This enable to have Lidar up to 100hz -->
        <LiveSource interval="10" />
      </Hints>
    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
