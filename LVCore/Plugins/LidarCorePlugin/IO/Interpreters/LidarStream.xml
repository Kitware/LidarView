<ServerManagerConfiguration>
  <ProxyGroup name="internal_interpreter">
    <!-- ==================================================================== -->
    <!-- Common lidar live source stream -->
    <SourceProxy name="CommonLidarStream"
                 class="vtkLidarStream"
                 base_proxygroup="internal_interpreter"
                 base_proxyname="BaseStream">

      <OutputPort name="Frame" index="0" />
      <OutputPort name="Calibration" index="1" />

      <IntVectorProperty name="DetectFrameDropping"
                         animateable="0"
                         command="SetDetectFrameDropping"
                         default_values="0"
                         number_of_elements="1"
                         panel_visibility="advanced">
        <BooleanDomain name="bool" />
        <Documentation>
          Throw a warning to the user each time a frame is dropped
        </Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Stream Options">
        <Property name="DetectFrameDropping" panel_visibility="advanced" />
      </PropertyGroup>
    </SourceProxy>

    <!-- ==================================================================== -->
    <!-- Common position orientation live source stream -->
    <SourceProxy name="CommonLidarPoseStream"
                 class="vtkLidarPoseStream"
                 base_proxygroup="internal_interpreter"
                 base_proxyname="BaseStream">

      <OutputPort name="Position Orientation" index="0" />
      <OutputPort name="Raw informations" index="1" />

    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
