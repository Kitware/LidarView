<ServerManagerConfiguration>
  <ProxyGroup name="internal_interpreter">
    <!-- ==================================================================== -->
    <!-- Common lidar live source stream -->
    <SourceProxy name="CommonLidarStream"
                 class="vtkLidarStream"
                 base_proxygroup="internal_interpreter"
                 base_proxyname="BaseStream">

      <OutputPort name="Frame" index="0" />
      <OutputPort name="Calibration" index="1" />

      <IntVectorProperty name="DetectFrameDropping"
                         animateable="0"
                         command="SetDetectFrameDropping"
                         default_values="0"
                         number_of_elements="1"
                         panel_visibility="advanced">
        <BooleanDomain name="bool" />
        <Documentation>
          Throw a warning to the user each time a frame is dropped
        </Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Stream Options">
        <Property name="DetectFrameDropping" panel_visibility="advanced" />
      </PropertyGroup>
    </SourceProxy>

    <!-- ==================================================================== -->
    <!-- Common pose live source stream -->
    <SourceProxy name="CommonLidarPoseStream"
                 class="vtkLidarPoseStream"
                 base_proxygroup="internal_interpreter"
                 base_proxyname="CommonLidarStream">

      <OutputPort name="Pose" index="2" />
      <OutputPort name="Pose Raw informations" index="3" />

      <IntVectorProperty name="ListeningPort"
                         label="LiDAR Port"
                         animateable="0"
                         command="SetListeningPort"
                         default_values="2368"
                         override="1"
                         number_of_elements="1">
        <Documentation>
        Specify port on which to listen for packets
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty name="GNSSPort"
                         label="GNSS / GPS Port"
                         animateable="0"
                         command="SetGNSSPort"
                         default_values="8308"
                         number_of_elements="1">
        <Documentation>
        Specify port on which to listen for packets
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty name="ForwardedPort"
                         label="Forward LiDAR Port"
                         animateable="0"
                         command="SetForwardedPort"
                         default_values="2369"
                         override="1"
                         number_of_elements="1"
                         panel_visibility="advanced">
        <Documentation>
          Specify lidar port on which to forward all packets received by the stream.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="IsForwarding"
                                   value="1" />
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty name="GNSSForwardedPort"
                         label="Forward GNSS / GPS Port"
                         animateable="0"
                         command="SetGNSSForwardedPort"
                         default_values="8308"
                         number_of_elements="1"
                         panel_visibility="advanced">
        <Documentation>
          Specify GNSS/GPS port on which to forward the pose packets received by the stream.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="IsForwarding"
                                   value="1" />
        </Hints>
      </IntVectorProperty>

      <PropertyGroup label="Stream Options">
        <Property name="MulticastAddress" />
        <Property name="LocalListeningAddress" />
        <Property name="ListeningPort" />
        <Property name="GNSSPort" />
        <Property name="IsCrashAnalysing" panel_visibility="advanced" />
      </PropertyGroup>

      <PropertyGroup label="Forward Stream">
        <Property name="IsForwarding" panel_visibility="advanced" />
        <Property name="ForwardedIpAddress" panel_visibility="advanced" />
        <Property name="ForwardedPort" panel_visibility="advanced" />
        <Property name="GNSSForwardedPort" panel_visibility="advanced" />
      </PropertyGroup>
    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
