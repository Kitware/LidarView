<ServerManagerConfiguration>
  <ProxyGroup name="filters">
    <SourceProxy name="CalibrationEvaluation"
                 class="vtkCalibrationEvaluation"
                 label="Evaluate Calibration">
      <Documentation short_help="Sweep LiDAR extrinsics (RPY/XYZ) and rank by voxel occupancy">
      Sweeps roll/pitch/yaw and X/Y/Z around the LiDAR-trajectory transform, aggregates selected frames,
      and scores by occupied voxels (lower is better).
      Use to verify or fine-tune extrinsics; set sweep ranges/steps, frame subset/stride, and voxel leaf size.
      </Documentation>

      <InputProperty name="PointCloud"
                     port_index="0"
                     command="SetInputConnection">
        <ProxyGroupDomain name="groups">
          <Group name="sources" />
          <Group name="filters" />
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkDataObject" />
        </DataTypeDomain>
      </InputProperty>

      <InputProperty name="Trajectory"
                     port_index="1"
                     command="SetInputConnection">
        <ProxyGroupDomain name="groups">
          <Group name="sources" />
          <Group name="filters" />
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkPolyData" />
        </DataTypeDomain>
      </InputProperty>

      <IntVectorProperty name="Use Upstream Calibration"
                         command="SetUseUpstreamCalibration"
                         number_of_elements="1"
                         default_values="1">
        <BooleanDomain name="bool" />
        <Documentation>When enabled, use the upstream SensorTransform (if found) as the sweep center. When disabled, use the user-provided Base Position/Rotation.</Documentation>
      </IntVectorProperty>

      <SubProxy command="SetAggregator">
        <Proxy name="Aggregator"
               proxygroup="filters"
               proxyname="AggregatePointsFromTrajectoryOffline" />
        <LinkProperties>
          <Property name="PointCloud" with_property="PointCloud" />
          <Property name="Trajectory" with_property="Trajectory" />
        </LinkProperties>
        <ExposedProperties>
          <Property name="All Frames" />
          <Property name="First Frame" />
          <Property name="Last Frame" />
          <Property name="Step Size" />
          <Property name="Voxel Leaf Size" />
        </ExposedProperties>
      </SubProxy>

      <DoubleVectorProperty name="PositionInfo"
                            command="GetBasePosition"
                            number_of_elements="3"
                            information_only="1"
                            default_values="0 0 0">
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Position"
                            command="SetBasePosition"
                            number_of_elements="3"
                            information_property="PositionInfo"
                            default_values="0 0 0">
        <Documentation>Base LiDAR position (meters) used as sweep center.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="Use Upstream Calibration"
                                   value="0" />
        </Hints>
      </DoubleVectorProperty>

      <DoubleVectorProperty name="RotationInfo"
                            command="GetBaseRotationDeg"
                            number_of_elements="3"
                            information_only="1"
                            default_values="0 0 0">
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Rotation"
                            command="SetBaseRotationDeg"
                            number_of_elements="3"
                            information_property="RotationInfo"
                            default_values="0 0 0">
        <Documentation>Base LiDAR orientation (roll, pitch, yaw in degrees) used as sweep center.</Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="Use Upstream Calibration"
                                   value="0" />
        </Hints>
      </DoubleVectorProperty>

      <PropertyGroup label="Calibration Reference Pose">
        <Property name="Position"/>
        <Property name="Rotation"/>
      </PropertyGroup>

      <PropertyGroup label="Upstream Calibration">
        <Property name="Use Upstream Calibration" />
      </PropertyGroup>

      <DoubleVectorProperty name="Translation Range"
                            command="SetTranslationRangeM"
                            number_of_elements="3"
                            default_values="0 0 0">
        <Documentation>Half-range in meters for X, Y, Z. Sweep is centered on the upstream sensor translation and spans [-range, +range] per axis.</Documentation>
      </DoubleVectorProperty>

      <IntVectorProperty name="Translation Steps"
                         command="SetTranslationSteps"
                         number_of_elements="3"
                         default_values="1 1 1">
        <IntRangeDomain name="range"
                        min="0"
                        max="1001" />
        <Documentation>Number of samples along X, Y, Z. A value ≤ 1 disables sweep on that axis (center only).</Documentation>
      </IntVectorProperty>

      <DoubleVectorProperty name="Angle Range"
                            command="SetAngleRangeDeg"
                            number_of_elements="3"
                            default_values="0 0 0">
        <Documentation>Half-range in degrees for Roll, Pitch, Yaw. Sweep spans [-range, +range] around the upstream sensor orientation.</Documentation>
      </DoubleVectorProperty>

      <IntVectorProperty name="Angle Steps"
                         command="SetAngleSteps"
                         number_of_elements="3"
                         default_values="1 1 1">
        <IntRangeDomain name="range"
                        min="0"
                        max="1001" />
        <Documentation>Number of samples for Roll, Pitch, Yaw. A value ≤ 1 disables sweep on that axis (center only).</Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Translation Sweep">
        <Property name="Translation Range" />
        <Property name="Translation Steps" />
      </PropertyGroup>

      <PropertyGroup label="Rotation Sweep">
        <Property name="Angle Range" />
        <Property name="Angle Steps" />
      </PropertyGroup>

      <PropertyGroup label="Input frames">
        <Property name="All Frames" />
        <Property name="First Frame" />
        <Property name="Last Frame" />
        <Property name="Step Size" />
      </PropertyGroup>

      <PropertyGroup label="Voxel grid parameters">
        <Property name="Voxel Leaf Size" />
      </PropertyGroup>

    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
