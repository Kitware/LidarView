<ServerManagerConfiguration>
  <!-- Begin ComputeNormalAdaptive -->
  <ProxyGroup name="filters">
    <SourceProxy name="ComputeNormalAdaptive" class="vtkComputeNormalAdaptive" label="Compute Normal Adaptive">
      <Documentation
        short_help="Compute normals of a point cloud using adaptive PCA"
        long_help="Compute normals of a point cloud using adaptive PCA">
        Compute normal vectors of a point cloud using adaptive PCA. The algorithm will run a weighted iterative
        PCA to compute the normal vector of each point from its neighbourhood. This method is robust to computing normals
        in intersections of planes.
      </Documentation>

    <InputProperty
      name="PointCloud"
      port_index="0"
      command="SetInputConnection">
      <DataTypeDomain name="input_type">
        <DataType value="vtkPolyData"/>
      </DataTypeDomain>
      <Documentation>
        Set the input pointcloud.
      </Documentation>
    </InputProperty>

    <OutputPort name="Point cloud with normals" index="0" />

    <IntVectorProperty name="Search Mode"
                       command="SetSearchMode"
                       number_of_elements="1"
                       default_values="1">
      <EnumerationDomain name="enum">
        <Entry value="0" text="Knn"/>
        <Entry value="1" text="Radius"/>
      </EnumerationDomain>
      <Documentation>
        Choose the method to use for searching neighbours of a point
      </Documentation>
    </IntVectorProperty>

    <IntVectorProperty name="Number Neighbours Threshold"
                       command="SetNumberNeighbors"
                       number_of_elements="1"
                       default_values="3">
      <Documentation>
        Set number of neighbours threshold
      </Documentation>
    </IntVectorProperty>

    <DoubleVectorProperty name="Radius Threshold"
                          command="SetRadius"
                          number_of_elements="1"
                          default_values="0.1">
      <Documentation>
        Set neighbours radius threshold
      </Documentation>
    </DoubleVectorProperty>

    <DoubleVectorProperty name="Point cloud noise"
                          command="SetNoise"
                          number_of_elements="1"
                          default_values="0.000001">
      <Documentation>
        Set noise of point cloud
      </Documentation>
    </DoubleVectorProperty>

    <IntVectorProperty name="Denoise"
                       command="SetDenoise"
                       number_of_elements="1"
                       default_values="0">
      <BooleanDomain name="bool"/>
      <Documentation>
        Choose whether to denoise point cloud or not
      </Documentation>
    </IntVectorProperty>

    <IntVectorProperty name="Orient"
                       command="SetOrient"
                       number_of_elements="1"
                       default_values="0">
      <BooleanDomain name="bool"/>
      <Documentation>
        Choose whether to orient normals of the same plan in the same direction or keep them as computed
      </Documentation>
    </IntVectorProperty>

    </SourceProxy>
  </ProxyGroup>
  <!-- End ComputeNormalAdaptive -->
</ServerManagerConfiguration>
