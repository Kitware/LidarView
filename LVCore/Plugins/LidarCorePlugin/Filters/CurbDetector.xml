<ServerManagerConfiguration>
  <ProxyGroup name="filters">
    <SourceProxy name="CurbDetector" class="vtkCurbDetector" label="Curb Detector">
      <Documentation short_help="Detect curb edges (left/right) within a 3D ROI.">
        Extracts curb points in real-time from a LiDAR point cloud within a 3D region of interest.
        It detects the left and right curb edges inside the ROI.
      </Documentation>

      <InputProperty name="Input" port_index="0" command="SetInputConnection">
        <ProxyGroupDomain name="groups">
          <Group name="sources"/>
          <Group name="filters"/>
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkPolyData"/>
        </DataTypeDomain>
        <Documentation>Set the input polydata.</Documentation>
      </InputProperty>

      <OutputPort name="FilteredPoints" index="0" id="port0" />
      <OutputPort name="CurbPointsLR" index="1" id="port1" />

      <DoubleVectorProperty name="ZChangeMin" label="Minimum Z Change (m)" command="SetZChangeMin" number_of_elements="1" default_values="0.1">
        <Documentation>Minimum total ΔZ over X-ordered neighbors (meters).</Documentation>
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Position" command="SetBoxPosition" number_of_elements="3"
                            default_values="-10 5 -3">
        <Documentation>Interactive box origin/min-corner (x y z).</Documentation>
      </DoubleVectorProperty>
      <DoubleVectorProperty name="Scale" command="SetBoxScale" number_of_elements="3"
                            default_values="15 25 2">
        <Documentation>Interactive box lengths (x y z).</Documentation>
      </DoubleVectorProperty>

      <PropertyGroup label="Filter">
        <Property name="ZChangeMin" />
      </PropertyGroup>
      <PropertyGroup label="Region of interest (ROI)" panel_widget="InteractiveBox">
        <Property name="Position" />
        <Property name="Scale" />
      </PropertyGroup>

    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
