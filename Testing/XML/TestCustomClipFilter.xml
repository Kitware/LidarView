<?xml version="1.0" ?>
<pqevents>
  <!-- Generate point cloud -->
  <pqevent object="LidarViewMainWindow/menubar/menuSources/Alphabetical" command="activate" arguments="PointSource" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/NumberOfPoints/LineEdit0" command="set_string" arguments="1000" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/Radius/DoubleLineEdit0" command="set_string" arguments="20" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/Accept" command="activate" arguments="" />
  <pqevent object="LidarViewMainWindow/menubar/menuFilters/Alphabetical" command="activate" arguments="ConvertToPointCloud" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/Accept" command="activate" arguments="" />

  <!-- Add a Clip Point Filter -->
  <pqevent object="LidarViewMainWindow/menubar/menuFilters/pqProxyGroupMenuManager0/ClipPoints" command="activate" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/ClipFunction/ProxySelectionWidget/comboBox" command="activated" arguments="Cylinder" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/Invert/CheckBox" command="set_boolean" arguments="true" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/ClipFunction/ProxySelectionWidget/frame/ChosenProxyWidget/InteractiveCylinder/radius" command="set_string" arguments="10" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/Accept" command="activate" arguments="" />

  <!-- Remove grid & reset camera -->
  <pqevent object="LidarViewMainWindow/menubar/menuEdit" command="activate" arguments="actionShowMeasurementGrid" />
  <pqevent object="LidarViewMainWindow/cameraToolbar/actionResetCameraClosest" command="activate" arguments="" />

  <!-- Create custom filter -->
  <pqevent object="LidarViewMainWindow/menubar/menuTools" command="activate" arguments="actionToolsCreateCustomFilter" />
  <pqevent object="LidarViewMainWindow/pqCustomFilterDefinitionWizard/InputFrame/PageStack/NamePage/CustomFilterName" command="set_string" arguments="CustomFilter" />
  <pqevent object="LidarViewMainWindow/pqCustomFilterDefinitionWizard/InputFrame/FinishButton" command="activate" arguments="" />

  <!-- Delete original Clip -->
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/Delete" command="activate" arguments="" />

  <!-- Apply custom filter -->
  <pqevent object="LidarViewMainWindow/menubar" command="activate" arguments="menuFilters" />
  <pqevent object="LidarViewMainWindow/menubar/menuFilters" command="activate" arguments="&amp;Alphabetical" />
  <pqevent object="LidarViewMainWindow/menubar/menuFilters/Alphabetical" command="activate" arguments="CustomFilter" />
  <pqevent object="LidarViewMainWindow" command="set_tab_with_text" arguments="Properties" />
  <pqevent object="LidarViewMainWindow/propertiesDock/propertiesPanel/Accept" command="activate" arguments="" />
</pqevents>
